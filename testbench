library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity tb_reconhecimento is
end tb_reconhecimento;

architecture sim of tb_reconhecimento is

    signal clk          : STD_LOGIC := '0';
    signal reset        : STD_LOGIC := '0';
    signal face_valid   : STD_LOGIC := '0';
    signal face_id      : STD_LOGIC_VECTOR(7 downto 0);

    signal face_ok      : STD_LOGIC;
    signal face_error   : STD_LOGIC;
    signal processando  : STD_LOGIC;

begin

    uut: entity work.reconhecimento_facial
        port map(
            clk => clk,
            reset => reset,
            face_valid => face_valid,
            face_id => face_id,
            face_ok => face_ok,
            face_error => face_error,
            processando => processando
        );

    clk_process : process
    begin
        clk <= '0';
        wait for 5 ns;

        clk <= '1';
        wait for 5 ns;
    end process;

    stim_proc: process
    begin

        reset <= '1';
        wait for 20 ns;

        reset <= '0';

        face_valid <= '1';
        face_id <= "10101010";

        wait for 40 ns;

        face_valid <= '0';

        wait for 50 ns;

        face_valid <= '1';
        face_id <= "11110000";

        wait for 40 ns;

        face_valid <= '0';

        wait;

    end process;

end sim;
